rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public can view/read all images, only authenticated admin can write (upload/delete)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'famoushdbiryanii@gmail.com';
    }
  }
}
